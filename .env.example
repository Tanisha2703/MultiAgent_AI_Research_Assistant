# ── PRIMARY LLM ────────────────────────────────────────────────────────────
# OpenAI (preferred) — https://platform.openai.com
OPENAI_API_KEY=sk-...

# ── FALLBACK LLM (used automatically when OPENAI_API_KEY is not set) ───────
# NVIDIA free tier — https://build.nvidia.com/  (no credit card required)
# Provides: meta/llama-3.3-70b-instruct (LLM) + nvidia/nv-embedqa-e5-v5 (embeddings)
NVIDIA_API_KEY=nvapi-...

# ── WEB SEARCH ─────────────────────────────────────────────────────────────
# Tavily — https://tavily.com (free tier: 1000 req/month)
TAVILY_API_KEY=tvly-...

# Optional overrides (defaults shown)
# LLM_MODEL=gpt-4o-mini
# EMBEDDING_MODEL=text-embedding-3-small
# CHUNK_SIZE=1000
# CHUNK_OVERLAP=200
# TOP_K_RETRIEVAL=5
# MAX_FILE_SIZE_MB=10
